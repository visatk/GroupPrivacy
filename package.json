{
  "name": "group",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade Telegram Group Manager Bot on Cloudflare Workers",
  "scripts": {
    "deploy": "npm run db:migrate && npm run cf-typegen && wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "test": "vitest",
    "cf-typegen": "wrangler types",
    "db:create": "wrangler d1 create groupprivacyplusbot-db",
    "db:migrate": "wrangler d1 execute groupprivacyplusbot-db --file=schema.sql --remote",
    "db:migrate:local": "wrangler d1 execute groupprivacyplusbot-db --local --file=schema.sql",
    "webhook:set": "node scripts/set-webhook.mjs",
    "webhook:delete": "node scripts/delete-webhook.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@cloudflare/workers-types": "^4.20260203.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.5.2",
    "vitest": "~3.2.0",
    "wrangler": "^4.87.0"
  }
}
